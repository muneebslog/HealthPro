    - database/factories/ServiceFactory.php
    - database/factories/ServicePriceFactory.php
    - database/factories/InvoiceFactory.php
    - database/factories/InvoiceServiceFactory.php
    - database/factories/VisitFactory.php
    - database/factories/VisitServiceFactory.php
    - database/factories/QueueFactory.php
    - database/factories/QueueTokenFactory.php
    - database/migrations/2026_03_10_143542_create_patients_table.php
    - database/migrations/2026_03_10_143543_create_families_table.php
    - database/migrations/2026_03_10_143544_create_doctors_table.php
    - database/migrations/2026_03_10_143545_create_services_table.php
    - database/migrations/2026_03_10_143546_create_service_prices_table.php
